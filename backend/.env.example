# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Amazon Nova API (OpenAI-compatible text completions)
NOVA_API_KEY=your-nova-api-key
NOVA_BASE_URL=https://api.nova.amazon.com/v1

# Amazon Nova Models
NOVA_SCENARIO_MODEL=nova-2-lite-v1
NOVA_AGENT_MODEL=nova-2-lite-v1
NOVA_FAST_MODEL=nova-2-lite-v1
NOVA_VISION_MODEL=nova-2-lite-v1

# AWS Credentials (for Nova Sonic via LiveKit + Bedrock)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# Nova Sonic voice settings
NOVA_SONIC_VOICE=tiffany
NOVA_SONIC_TURN_DETECTION=MEDIUM

# Google Gemini Fallback (used automatically if AWS Nova is unavailable or fails)
# On startup, AWS credentials are validated. If invalid, Gemini becomes the active provider.
# If AWS fails mid-session, the process switches to Gemini for the rest of the run.
GOOGLE_API_KEY=your-google-api-key
# Gemini 3 is the flagship model; voices are assigned per-agent by the Scenario Analyst
GEMINI_AGENT_MODEL=gemini-3-flash
GEMINI_SCENARIO_MODEL=gemini-3-flash
GEMINI_FAST_MODEL=gemini-3-flash
GEMINI_VISION_MODEL=gemini-3-flash
GEMINI_REALTIME_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# LiveKit (required for backend-managed LiveKit voice transport)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Firestore
FIRESTORE_EMULATOR_HOST=localhost:8080  # Set only for local dev

# FastAPI
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development  # "development" uses local storage, "production" uses Firebase
VOICE_BACKEND=livekit_aws
SINGLE_AGENT_VOICE_MODE=false
MAX_AGENTS_PER_SESSION=4

# Pub/Sub
PUBSUB_EMULATOR_HOST=localhost:8085  # Set only for local dev
PUBSUB_TOPIC=war-room-events
